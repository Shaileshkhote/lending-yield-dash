BASE_RPC_URL=""

# Required for the shipped Aave, Spark, and Compound adapters.
THE_GRAPH_API_KEY=""
THE_GRAPH_GATEWAY_URL="https://gateway.thegraph.com/api"
AAVE_V3_ETHEREUM_SUBGRAPH_ID="Cd2gEDVeqnjBn1hSeqFMitw8Q1iiyV9FYUZkLNRcL87g"
AAVE_V3_BASE_SUBGRAPH_ID="GQFbb95cE6d8mV989mL5figjaGaKCQB3xqYrr1bRyXqF"
SPARK_ETHEREUM_SUBGRAPH_ID="GbKdmBe4ycCYCQLQSjqGg6UHYoYfbyJyq5WrG35pv1si"
