DATABASE_URL="postgresql://lendingscope:lendingscope@localhost:5432/lendingscope?schema=public"
ADMIN_API_KEY="dev-admin-key"
PORT="4000"

# Frontend. For Netlify, set this to the deployed Nest API base URL.
NEXT_PUBLIC_API_BASE_URL="https://69.48.229.8.sslip.io"

# Optional RPC endpoints. Current adapters are subgraph-only, but history/backfill uses RPC
# to resolve date -> block numbers. The history CLI falls back to public RPCs if these are empty.
